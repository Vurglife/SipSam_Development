{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_TOOL_SEARCH": "auto"
  },
  "enabledMcpjsonServers": [
    "vurglife-sqlite-readonly"
  ],
  "cleanupPeriodDays": 14,
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(npm start *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm ci *)",
      "Bash(npm install *)",
      "Bash(cp vurglife-platform/data/*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(rm *)",
      "Bash(del *)",
      "Bash(Remove-Item *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./secrets/**)",
      "Read(./**/secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/node_modules/**)",
      "Read(./.git/**)",
      "Read(./.claude/worktrees/**)",
      "Read(./.claude/.claude/worktrees/**)",
      "Read(./**/*.tmp)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)",
      "Edit(./**/*.db)",
      "Write(./**/*.db)",
      "Edit(./vurglife-platform/data/vurglife.db*)",
      "Write(./vurglife-platform/data/vurglife.db*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/scripts/ship-gate.js",
            "timeout": 60,
            "statusMessage": "Ship-gate: syntax/JSON validation"
          }
        ]
      }
    ]
  }
}
