# ============================================
# VURGLIFE PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ============================================

# Server
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Security — CHANGE THIS before going live!
JWT_SECRET=vurglife_CHANGE_THIS_TO_RANDOM_64_CHAR_STRING_BEFORE_PRODUCTION

# Email (Resend.com — get free API key at resend.com)
RESEND_API_KEY=re_your_key_here

# SipSam WebSocket port
SIPSAM_WS_PORT=3001

# --- PRODUCTION ADDITIONS (fill when going live) ---
# BASE_URL=https://vurglife.com
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# PAYPAL_CLIENT_ID=...
# PAYPAL_SECRET=...
# DO_SPACES_KEY=...
# DO_SPACES_SECRET=...
# DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# DO_SPACES_BUCKET=vurglife-assets
