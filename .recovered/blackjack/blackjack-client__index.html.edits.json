    "new_string": "function igmShowRules(){document.getElementById('igm-sub-rules').classList.add('open');}\nfunction igmShowPayouts(){\n  // Tier badge — Blackjack tier defined by tableMinBet (no isVip flag yet, but show table info)\n  var minBet=(igmTableCfg&&igmTableCfg.minBet)||100;\n  var tier=document.getElementById('igm-payouts-tier');\n  if(tier){\n    tier.style.background='rgba(26,140,255,.08)';tier.style.border='1px solid #1a2d50';tier.style.color='#7a9ac0';\n    tier.textContent=(minBet>=10000?'💎 VIP TABLE':'Standard table')+' (min bet $'+minBet.toLocaleString()+')';\n    if(minBet>=10000){tier.style.background='linear-gradient(135deg, rgba(201,168,76,.15), rgba(232,201,106,.05))';tier.style.border='1px solid #c9a84c';tier.style.color='#e8c96a';}\n  }\n  document.getElementById('igm-sub-payouts').classList.add('open');\n}",
