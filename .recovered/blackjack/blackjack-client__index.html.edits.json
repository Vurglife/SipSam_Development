    "old_string": "  <!-- Rules sub -->\n  <div id=\"igm-sub-rules\" class=\"igm-sub\" style=\"overflow-y:auto\">",
    "new_string": "  <!-- Payouts & Specials — focused payout reference -->\n  <div id=\"igm-sub-payouts\" class=\"igm-sub\" style=\"overflow-y:auto\">\n    <div class=\"igm-sub-head\" style=\"position:sticky;top:0;z-index:1;background:#080f1e\"><button onclick=\"igmBack()\" class=\"igm-back-btn\">← Back</button><span>Payouts &amp; Specials</span></div>\n    <div style=\"padding:16px;font-size:12px;line-height:1.6;color:#7a9ac0\">\n\n      <div id=\"igm-payouts-tier\" style=\"margin-bottom:12px;padding:8px 12px;border-radius:7px;font-size:11px;font-weight:700;letter-spacing:1px;text-align:center;text-transform:uppercase\"></div>\n\n      <!-- Main bet payouts -->\n      <div class=\"igm-rule-sec\">\n        <div class=\"igm-rule-h\">💰 Main Bet Payouts</div>\n        <table style=\"width:100%;border-collapse:collapse;font-size:11px\">\n          <tbody>\n            <tr style=\"border-bottom:1px solid rgba(255,255,255,.05)\"><td style=\"padding:5px 6px\">Blackjack (A + 10-value)</td><td style=\"text-align:right;padding:5px 6px;color:#ffd700;font-weight:700\">3:2 (1.5×)</td></tr>\n            <tr style=\"border-bottom:1px solid rgba(255,255,255,.05)\"><td style=\"padding:5px 6px\">Win round</td><td style=\"text-align:right;padding:5px 6px;color:#22c55e;font-weight:700\">1:1</td></tr>\n            <tr style=\"border-bottom:1px solid rgba(255,255,255,.05)\"><td style=\"padding:5px 6px\">Push (tie value, no tie bet)</td><td style=\"text-align:right;padding:5px 6px;color:#7a9ac0;font-weight:700\">bet returned</td></tr>\n            <tr style=\"border-bottom:1px solid rgba(255,255,255,.05)\"><td style=\"padding:5px 6px\">Insurance (dealer Blackjack)</td><td style=\"text-align:right;padding:5px 6px;color:#22c55e;font-weight:700\">2:1</td></tr>\n            <tr><td style=\"padding:5px 6px\">Lose / bust</td><td style=\"text-align:right;padding:5px 6px;color:#ef4444;font-weight:700\">−1× bet</td></tr>\n          </tbody>\n        </table>\n      </div>\n\n      <!-- Tie bet -->\n      <div class=\"igm-rule-sec\">\n        <div class=\"igm-rule-h\">🎯 Tie Bet (optional)</div>\n        <p style=\"margin:0 0 6px;font-size:11px\">Place during betting phase. Wins a flat bonus when your total equals the dealer's — even if both bust at the same total.</p>\n        <table style=\"width:100%;border-collapse:collapse;font-size:11px\">\n          <tbody>\n            <tr style=\"border-bottom:1px solid rgba(255,255,255,.05)\"><td style=\"padding:5px 6px\">$100 main bet → tie</td><td style=\"text-align:right;padding:5px 6px;color:#ffd700;font-weight:700\" id=\"igm-bj-tie-100\">+$2,000</td></tr>\n            <tr><td style=\"padding:5px 6px\">$500 main bet → tie</td><td style=\"text-align:right;padding:5px 6px;color:#ffd700;font-weight:700\" id=\"igm-bj-tie-500\">+$3,000</td></tr>\n          </tbody>\n        </table>\n        <p style=\"margin:6px 0 0;font-size:10.5px\">If your tie hand is also a Blackjack, it counts as Blackjack (3:2) instead of Push, plus the tie bonus.</p>\n      </div>\n\n      <!-- Caribbean side bets -->\n      <div class=\"igm-rule-sec\">\n        <div class=\"igm-rule-h\">🏝 Caribbean Side Bets</div>\n        <table style=\"width:100%;border-collapse:collapse;font-size:11px\">\n          <thead>\n            <tr style=\"color:#4aabff;border-bottom:1px solid #1a2d50\">\n              <th style=\"text-align:left;padding:4px 6px;font-weight:700;letter-spacing:.5px\">SIDE BET</th>\n              <th style=\"text-align:center;padding:4px 6px;font-weight:700;letter-spacing:.5px\">MULT</th>\n              <th style=\"text-align:right;padding:4px 6px;font-weight:700;letter-spacing:.5px\">BONUS</th>\n            </tr>\n          </thead>\n          <tbody>\n            <tr style=\"border-bottom:1px solid rgba(255,255,255,.05)\"><td style=\"padding:5px 6px;color:#e8c96a\">Island BJ — Suited A+K</td><td style=\"text-align:center;padding:5px 6px;color:#22c55e;font-weight:700\">3:1</td><td style=\"text-align:right;padding:5px 6px;color:#4aabff;font-weight:700\">+$500</td></tr>\n            <tr style=\"border-bottom:1px solid rgba(255,255,255,.05)\"><td style=\"padding:5px 6px;color:#e8c96a\">Triple 7s — three 7s</td><td style=\"text-align:center;padding:5px 6px;color:#22c55e;font-weight:700\">5:1</td><td style=\"text-align:right;padding:5px 6px;color:#4aabff;font-weight:700\">+$2,500</td></tr>\n            <tr style=\"border-bottom:1px solid rgba(255,255,255,.05)\"><td style=\"padding:5px 6px;color:#e8c96a\">Rum Runner — 3-card 21</td><td style=\"text-align:center;padding:5px 6px;color:#22c55e;font-weight:700\">4:1</td><td style=\"text-align:right;padding:5px 6px;color:#4aabff;font-weight:700\">+$1,000</td></tr>\n            <tr style=\"border-bottom:1px solid rgba(255,255,255,.05)\"><td style=\"padding:5px 6px;color:#e8c96a\">Dealer Bust @ 22</td><td style=\"text-align:center;padding:5px 6px;color:#22c55e;font-weight:700\">1.5:1</td><td style=\"text-align:right;padding:5px 6px;color:#445566\">—</td></tr>\n            <tr><td style=\"padding:5px 6px;color:#e8c96a\">Full Sweep — 5 wins in a row</td><td style=\"text-align:center;padding:5px 6px;color:#22c55e;font-weight:700\">2× bonus</td><td style=\"text-align:right;padding:5px 6px;color:#445566\">—</td></tr>\n          </tbody>\n        </table>\n      </div>\n\n    </div>\n  </div>\n\n  <!-- Rules sub -->\n  <div id=\"igm-sub-rules\" class=\"igm-sub\" style=\"overflow-y:auto\">",
